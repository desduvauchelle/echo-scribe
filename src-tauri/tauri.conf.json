{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echo Scribe",
  "version": "0.1.0",
  "identifier": "com.echoscribe.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Echo Scribe",
        "width": 900,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": [10, 10, 10, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/echo-scribe-syscap", "binaries/echo-scribe-calmatch", "binaries/echo-scribe-screenrec"],
    "category": "Productivity",
    "resources": [
      "resources/tray_idle.png",
      "resources/tray_idle_dark.png",
      "resources/tray_recording.png",
      "resources/tray_recording_dark.png",
      "resources/tray_transcribing.png",
      "resources/tray_transcribing_dark.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "infoPlist": "Info.plist",
      "signingIdentity": "C985C7ED86CE02D998B394A554991B78D4687B2A",
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {}
}
