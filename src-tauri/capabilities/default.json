{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and overlay",
  "windows": ["main", "recording_overlay", "consent_overlay", "guide_overlay", "screenrec_setup", "camera_preview", "area_picker", "countdown"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-hide",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/echo-scribe-syscap", "sidecar": true, "args": [] }
      ]
    },
    "autostart:default",
    "notification:default",
    "dialog:default"
  ]
}
